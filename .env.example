# 텔레그램 봇 설정
# 1. @BotFather → /newbot 으로 봇 생성 후 토큰 발급
# 2. 봇과 대화 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 카카오 나에게 보내기 설정
# python kakao_setup.py 실행하면 자동 저장됨
# 수동 설정 시: developers.kakao.com → 내 앱 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_ACCESS_TOKEN=
KAKAO_REFRESH_TOKEN=
